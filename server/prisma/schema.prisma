// Prisma schema for POCKE — Student Expense Tracker.
//
// Provider is SQLite for development, but the schema is structured so
// that switching to PostgreSQL only requires changing the provider
// string below and re-running prisma migrate against the new database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User account. Holds credentials, onboarding figures, and JSON blobs
// for loosely-typed user preferences and custom categories.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash, never plaintext
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Headline financial figures captured during onboarding.
  income      Float    @default(0)
  expenses    Float    @default(0)
  onboarded   Boolean  @default(false)

  // UI preferences (theme, currency, etc.) stored as serialised JSON.
  // The schema is intentionally loose so the frontend can evolve
  // without database migrations.
  settingsJson String?

  // Custom categories the user has added on top of the built-in lists,
  // also stored as JSON arrays.
  customExpenseCategories String?
  customIncomeCategories  String?

  transactions      Transaction[]
  scheduledPayments ScheduledPayment[]
  goals             SavingsGoal[]
}

// Single income or expense entry.
model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "expense" | "income"
  name      String
  category  String
  amount    Float
  date      DateTime

  // For savings-related transactions: marks the source and links the
  // originating goal. Soft reference — deleting a goal does not cascade
  // because the user may want to keep the historical record.
  source    String?
  goalId    String?

  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([userId, type])
}

// Recurring subscription such as Netflix, Spotify, or a gym membership.
model ScheduledPayment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  amount    Float
  frequency String   // "weekly" | "monthly" | "yearly"
  startDate DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

// Savings target (e.g. "Holiday fund", "New laptop").
model SavingsGoal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  icon      String   @default("🎯")
  target    Float
  saved     Float    @default(0)
  color     String?

  createdAt DateTime @default(now())

  @@index([userId])
}
