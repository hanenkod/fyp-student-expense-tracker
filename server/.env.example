# POCKE backend environment variables
# Copy to .env and adjust as needed.

# SQLite file location — relative to the prisma folder
DATABASE_URL="file:./dev.db"

# Used to sign JWT tokens. CHANGE THIS to a long random string in production.
JWT_SECRET="dev-only-change-me-to-a-long-random-string-in-production"

# Hours until JWT expires
JWT_EXPIRES_IN="168h"

# Port the API listens on
PORT=4000

# Allowed CORS origin (the frontend dev server). Leave * for development.
CORS_ORIGIN="http://localhost:5173"
